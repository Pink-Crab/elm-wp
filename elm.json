{
    "type": "package",
    "name": "Pink-Crab/elm-wp",
    "summary": "Typed WordPress primitives for Elm apps mounted via pinkcrab/elm-mount.",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "WP.Flags",
        "WP.User",
        "WP.Http",
        "WP.Notice",
        "WP.Clipboard"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm/http": "2.0.0 <= v < 3.0.0",
        "NoRedInk/elm-json-decode-pipeline": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
